##### EJERCICIO STRING
contrasena = "Python2026"
total_letras = 0
total_numeros = 0
veces_o = 0
for caracter in contrasena:
    if caracter.isalpha():  
        total_letras = total_letras + 1
        if caracter == 'o': 
            veces_o = veces_o + 1
    elif caracter.isdigit():  
        total_numeros = total_numeros + 1
print("\n--- Análisis de la contraseña ---")
print(f"Contraseña: {contrasena}")
print(f"Total de letras: {total_letras}")
print(f"Total de números: {total_numeros}")
print(f"Veces que aparece 'o': {veces_o}")
